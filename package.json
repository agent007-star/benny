{
  "name": "@benny-co/cli",
  "version": "0.1.0",
  "description": "Benny - AI代码助手，专为中文开发者打造。支持通义、文心、Kimi等国产AI模型，提供代码优化、注释生成、AI审查、Git工作流集成等功能。",
  "type": "module",
  "keywords": [
    "ai",
    "code-assistant",
    "chinese",
    "中文",
    "tongyi",
    "wenxin",
    "kimi",
    "code-review",
    "git",
    "cli",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "agent",
    "ai-agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/benny-co/benny"
  },
  "homepage": "https://github.com/benny-co/benny#readme",
  "license": "MIT",
  "bin": {
    "benny": "./dist/cli/index.js",
    "benny-ai": "./dist/cli/index.js",
    "benny-mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "start": "node dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "pack": "npm run build && npm pack"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "diff": "^5.2.0",
    "dotenv": "^16.4.0",
    "ora": "^8.0.0",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/diff": "^5.2.0",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
